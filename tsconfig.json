{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "shared/src/**/*.ts",
    "shared/test/**/*.ts",
    "agents/*/src/**/*.ts",
    "agents/*/test/**/*.ts"
  ]
}
